<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yexuhang.express.mapper.UsersMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.yexuhang.express.bean.Users">
        <id column="id" property="id" />
        <result column="username" property="username" />
        <result column="phone" property="phone" />
        <result column="email" property="email" />
        <result column="password" property="password" />
        <result column="real_name" property="realName" />
        <result column="id_card" property="idCard" />
        <result column="user_type" property="userType" />
        <result column="avatar_url" property="avatarUrl" />
        <result column="status" property="status" />
        <result column="is_verified" property="isVerified" />
        <result column="last_login_time" property="lastLoginTime" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, username, phone, email, password, real_name, id_card, user_type, avatar_url, status, is_verified, last_login_time, created_at, updated_at
    </sql>

</mapper>
